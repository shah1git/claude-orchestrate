*.bak
.DS_Store

# Телеметрия и артефакты прогонов — держим локально, из публичного репо исключены (2026-07-13).
# Без завершающего слэша: с 2026-07-18 telemetry — симлинк в приватный клон
# orchestrate-telemetry (machines/<hostname>), а шаблон со слэшем матчит только каталог.
skill/orchestrate/telemetry
benchmark/results/

# Python-артефакты инструментов
__pycache__/
.pytest_cache/

# Транзитные артефакты run-lane в <workdir>: agy пишет журнал-свидетель
# .run-lane-agy-*.log (путь попадает в конверт как evidence.log_path), grok-адаптер
# материализует промпт в .run-lane-grok-prompt-*.md. Это улики/скрэтч прогона, не
# исходники — держим локально, из репозитория исключаем (2026-07-22).
.run-lane-agy-*.log
.run-lane-grok-prompt-*.md
